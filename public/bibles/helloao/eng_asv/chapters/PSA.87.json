{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":87,"content":[{"type":"hebrew_subtitle","content":["A Psalm of the sons of Korah; a Song."]},{"type":"verse","number":1,"content":[{"text":"His foundation is in the holy mountains.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Jehovah loveth the gates of Zion","poem":1},{"lineBreak":true},{"text":"More than all the dwellings of Jacob.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Glorious things are spoken of thee,","poem":1},{"lineBreak":true},{"text":"O city of God. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"I will make mention of Rahab and Babylon as among them that know me:","poem":1},{"lineBreak":true},{"text":"Behold, Philistia, and Tyre, with Ethiopia:","poem":1},{"lineBreak":true},{"text":"This one was born there.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Yea, of Zion it shall be said, This one and that one was born in her;","poem":1},{"lineBreak":true},{"text":"And the Most High himself will establish her.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Jehovah will count, when he writeth up the peoples,","poem":1},{"lineBreak":true},{"text":"This one was born there. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"They that sing as well as they that dance shall say,","poem":1},{"lineBreak":true},{"text":"All my fountains are in thee.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/87.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/88.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/86.json","previousChapterAudioLinks":{},"numberOfVerses":7}
