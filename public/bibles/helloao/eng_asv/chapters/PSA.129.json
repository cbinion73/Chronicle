{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":129,"content":[{"type":"hebrew_subtitle","content":["A Song of Ascents."]},{"type":"verse","number":1,"content":[{"text":"Many a time have they afflicted me from my youth up,","poem":1},{"lineBreak":true},{"text":"Let Israel now say,","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Many a time have they afflicted me from my youth up:","poem":1},{"lineBreak":true},{"text":"Yet they have not prevailed against me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"The plowers plowed upon my back;","poem":1},{"lineBreak":true},{"text":"They made long their furrows.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Jehovah is righteous:","poem":1},{"lineBreak":true},{"text":"He hath cut asunder the cords of the wicked.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Let them be put to shame and turned backward,","poem":1},{"lineBreak":true},{"text":"All they that hate Zion.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Let them be as the grass upon the housetops,","poem":1},{"lineBreak":true},{"text":"Which withereth before it groweth up;","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Wherewith the reaper filleth not his hand,","poem":1},{"lineBreak":true},{"text":"Nor he that bindeth sheaves, his bosom:","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Neither do they that go by say,","poem":1},{"lineBreak":true},{"text":"The blessing of Jehovah be upon you;","poem":1},{"lineBreak":true},{"text":"We bless you in the name of Jehovah.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/129.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/130.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/128.json","previousChapterAudioLinks":{},"numberOfVerses":8}
