{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":62,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; after the manner of Jeduthun. A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"My soul waiteth in silence for God only:","poem":1},{"lineBreak":true},{"text":"From him cometh my salvation.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"He only is my rock and my salvation:","poem":1},{"lineBreak":true},{"text":"He is my high tower; I shall not be greatly moved.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"How long will ye set upon a man,","poem":1},{"lineBreak":true},{"text":"That ye may slay him, all of you,","poem":1},{"lineBreak":true},{"text":"Like a leaning wall, like a tottering fence?","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"They only consult to thrust him down from his dignity;","poem":1},{"lineBreak":true},{"text":"They delight in lies;","poem":1},{"lineBreak":true},{"text":"They bless with their mouth, but they curse inwardly. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"My soul, wait thou in silence for God only;","poem":1},{"lineBreak":true},{"text":"For my expectation is from him.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"He only is my rock and my salvation:","poem":1},{"lineBreak":true},{"text":"He is my high tower; I shall not be moved.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"With God is my salvation and my glory:","poem":1},{"lineBreak":true},{"text":"The rock of my strength, and my refuge, is in God.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Trust in him at all times, ye people;","poem":1},{"lineBreak":true},{"text":"Pour out your heart before him:","poem":1},{"lineBreak":true},{"text":"God is a refuge for us. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Surely men of low degree are vanity, and men of high degree are a lie:","poem":1},{"lineBreak":true},{"text":"In the balances they will go up;","poem":1},{"lineBreak":true},{"text":"They are together lighter than vanity.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Trust not in oppression,","poem":1},{"lineBreak":true},{"text":"And become not vain in robbery:","poem":1},{"lineBreak":true},{"text":"If riches increase, set not your heart thereon.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"God hath spoken once,","poem":1},{"lineBreak":true},{"text":"Twice have I heard this,","poem":1},{"lineBreak":true},{"text":"That power belongeth unto God.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"Also unto thee, O Lord, belongeth lovingkindness;","poem":1},{"lineBreak":true},{"text":"For thou renderest to every man according to his work.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/62.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/63.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/61.json","previousChapterAudioLinks":{},"numberOfVerses":12}
