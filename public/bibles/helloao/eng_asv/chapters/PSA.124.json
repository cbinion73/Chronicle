oul.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Blessed be Jehovah,","poem":1},{"lineBreak":true},{"text":"Who hath not given us as a prey to their teeth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Our soul is escaped as a bird out of the snare of the fowlers:","poem":1},{"lineBreak":true},{"text":"The snare is broken, and we are escaped.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Our help is in the name of Jehovah,","poem":1},{"lineBreak":true},{"text":"Who made heaven and earth.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/124.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/125.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/123.json","previousChapterAudioLinks":{},"numberOfVerses":8}
