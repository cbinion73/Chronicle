{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":54,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; on stringed instruments. Maschil of David; when the Ziphites came and said to Saul, Doth not David hide himself with us?"]},{"type":"verse","number":1,"content":[{"text":"Save me, O God, by thy name,","poem":1},{"lineBreak":true},{"text":"And judge me in thy might.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Hear my prayer, O God;","poem":1},{"lineBreak":true},{"text":"Give ear to the words of my mouth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"For strangers are risen up against me,","poem":1},{"lineBreak":true},{"text":"And violent men have sought after my soul:","poem":1},{"lineBreak":true},{"text":"They have not set God before them. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Behold, God is my helper:","poem":1},{"lineBreak":true},{"text":"The Lord is of them that uphold my soul.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"He will requite the evil unto mine enemies:","poem":1},{"lineBreak":true},{"text":"Destroy thou them in thy truth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"With a freewill-offering will I sacrifice unto thee:","poem":1},{"lineBreak":true},{"text":"I will give thanks unto thy name, O Jehovah, for it is good.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"For he hath delivered me out of all trouble;","poem":1},{"lineBreak":true},{"text":"And mine eye hath seen my desire upon mine enemies.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/54.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/55.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/53.json","previousChapterAudioLinks":{},"numberOfVerses":7}
