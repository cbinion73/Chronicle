ext":"Thou preparest a table before me in the presence of mine enemies:","poem":1},{"lineBreak":true},{"text":"Thou hast anointed my head with oil;","poem":1},{"lineBreak":true},{"text":"My cup runneth over.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Surely goodness and lovingkindness shall follow me all the days of my life;","poem":1},{"lineBreak":true},{"text":"And I shall dwell in the house of Jehovah for ever.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/23.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/24.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/22.json","previousChapterAudioLinks":{},"numberOfVerses":6}
