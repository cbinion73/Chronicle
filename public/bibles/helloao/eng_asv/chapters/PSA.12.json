{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":12,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; set to the Sheminith. A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Help, Jehovah; for the godly man ceaseth;","poem":1},{"lineBreak":true},{"text":"For the faithful fail from among the children of men.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"They speak falsehood every one with his neighbor:","poem":1},{"lineBreak":true},{"text":"With flattering lip, and with a double heart, do they speak.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Jehovah will cut off all flattering lips,","poem":1},{"lineBreak":true},{"text":"The tongue that speaketh great things;","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Who have said, With our tongue will we prevail;","poem":1},{"lineBreak":true},{"text":"Our lips are our own: who is lord over us?","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Because of the oppression of the poor, because of the sighing of the needy,","poem":1},{"lineBreak":true},{"text":"Now will I arise, saith Jehovah;","poem":1},{"lineBreak":true},{"text":"I will set him in the safety he panteth for.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"The words of Jehovah are pure words;","poem":1},{"lineBreak":true},{"text":"As silver tried in a furnace on the earth,","poem":1},{"lineBreak":true},{"text":"Purified seven times.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Thou wilt keep them, O Jehovah,","poem":1},{"lineBreak":true},{"text":"Thou wilt preserve them from this generation for ever.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"The wicked walk on every side,","poem":1},{"lineBreak":true},{"text":"When vileness is exalted among the sons of men.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/12.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/13.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/11.json","previousChapterAudioLinks":{},"numberOfVerses":8}
