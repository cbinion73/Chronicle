{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":121,"content":[{"type":"hebrew_subtitle","content":["A Song of Ascents."]},{"type":"verse","number":1,"content":[{"text":"I will lift up mine eyes unto the mountains:","poem":1},{"lineBreak":true},{"text":"From whence shall my help come?","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"My help cometh from Jehovah,","poem":1},{"lineBreak":true},{"text":"Who made heaven and earth.","poem":1}]},{"type":"line_break"},{"type":"verse","number":3,"content":[{"text":"He will not suffer thy foot to be moved:","poem":1},{"lineBreak":true},{"text":"He that keepeth thee will not slumber.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Behold, he that keepeth Israel","poem":1},{"lineBreak":true},{"text":"Will neither slumber nor sleep.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Jehovah is thy keeper:","poem":1},{"lineBreak":true},{"text":"Jehovah is thy shade upon thy right hand.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"The sun shall not smite thee by day,","poem":1},{"lineBreak":true},{"text":"Nor the moon by night.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Jehovah will keep thee from all evil;","poem":1},{"lineBreak":true},{"text":"He will keep thy soul.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Jehovah will keep thy going out and thy coming in","poem":1},{"lineBreak":true},{"text":"From this time forth and for evermore.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/121.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/122.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/120.json","previousChapterAudioLinks":{},"numberOfVerses":8}
