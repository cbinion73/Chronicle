{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":97,"content":[{"type":"verse","number":1,"content":[{"text":"Jehovah reigneth; let the earth rejoice;","poem":1},{"lineBreak":true},{"text":"Let the multitude of isles be glad.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Clouds and darkness are round about him:","poem":1},{"lineBreak":true},{"text":"Righteousness and justice are the foundation of his throne.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"A fire goeth before him,","poem":1},{"lineBreak":true},{"text":"And burneth up his adversaries round about.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"His lightnings lightened the world:","poem":1},{"lineBreak":true},{"text":"The earth saw, and trembled.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"The mountains melted like wax at the presence of Jehovah,","poem":1},{"lineBreak":true},{"text":"At the presence of the Lord of the whole earth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"The heavens declare his righteousness,","poem":1},{"lineBreak":true},{"text":"And all the peoples have seen his glory.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Let all them be put to shame that serve graven images,","poem":1},{"lineBreak":true},{"text":"That boast themselves of idols:","poem":1},{"lineBreak":true},{"text":"Worship him, all ye gods.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Zion heard and was glad,","poem":1},{"lineBreak":true},{"text":"And the daughters of Judah rejoiced,","poem":1},{"lineBreak":true},{"text":"Because of thy judgments, O Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"For thou, Jehovah, art most high above all the earth:","poem":1},{"lineBreak":true},{"text":"Thou art exalted far above all gods.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"O ye that love Jehovah, hate evil:","poem":1},{"lineBreak":true},{"text":"He preserveth the souls of his saints;","poem":1},{"lineBreak":true},{"text":"He delivereth them out of the hand of the wicked.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Light is sown for the righteous,","poem":1},{"lineBreak":true},{"text":"And gladness for the upright in heart.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"Be glad in Jehovah, ye righteous;","poem":1},{"lineBreak":true},{"text":"And give thanks to his holy memorial name.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/97.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/98.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/96.json","previousChapterAudioLinks":{},"numberOfVerses":12}
