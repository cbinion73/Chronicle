{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":141,"content":[{"type":"hebrew_subtitle","content":["A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Jehovah, I have called upon thee; make haste unto me:","poem":1},{"lineBreak":true},{"text":"Give ear unto my voice, when I call unto thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Let my prayer be set forth as incense before thee;","poem":1},{"lineBreak":true},{"text":"The lifting up of my hands as the evening sacrifice.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Set a watch, O Jehovah, before my mouth;","poem":1},{"lineBreak":true},{"text":"Keep the door of my lips.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Incline not my heart to any evil thing,","poem":1},{"lineBreak":true},{"text":"To practise deeds of wickedness","poem":1},{"lineBreak":true},{"text":"With men that work iniquity:","poem":1},{"lineBreak":true},{"text":"And let me not eat of their dainties.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Let the righteous smite me, it shall be a kindness;","poem":1},{"lineBreak":true},{"text":"And let him reprove me, it shall be as oil upon the head;","poem":1},{"lineBreak":true},{"text":"Let not my head refuse it:","poem":1},{"lineBreak":true},{"text":"For even in their wickedness shall my prayer continue.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Their judges are thrown down by the sides of the rock;","poem":1},{"lineBreak":true},{"text":"And they shall hear my words; for they are sweet.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"As when one ploweth and cleaveth the earth,","poem":1},{"lineBreak":true},{"text":"Our bones are scattered at the mouth of Sheol.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"For mine eyes are unto thee, O Jehovah the Lord:","poem":1},{"lineBreak":true},{"text":"In thee do I take refuge; leave not my soul destitute.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Keep me from the snare which they have laid for me,","poem":1},{"lineBreak":true},{"text":"And from the gins of the workers of iniquity.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Let the wicked fall into their own nets,","poem":1},{"lineBreak":true},{"text":"Whilst that I withal escape.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/141.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/142.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/140.json","previousChapterAudioLinks":{},"numberOfVerses":10}
