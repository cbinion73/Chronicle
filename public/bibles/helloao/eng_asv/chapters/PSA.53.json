{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":53,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; set to Mahalath. Maschil of David."]},{"type":"verse","number":1,"content":[{"text":"The fool hath said in his heart, There is no God.","poem":1},{"lineBreak":true},{"text":"Corrupt are they, and have done abominable iniquity;","poem":1},{"lineBreak":true},{"text":"There is none that doeth good.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"God looked down from heaven upon the children of men,","poem":1},{"lineBreak":true},{"text":"To see if there were any that did understand,","poem":1},{"lineBreak":true},{"text":"That did seek after God.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Every one of them is gone back; they are together become filthy;","poem":1},{"lineBreak":true},{"text":"There is none that doeth good, no, not one.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Have the workers of iniquity no knowledge,","poem":1},{"lineBreak":true},{"text":"Who eat up my people as they eat bread,","poem":1},{"lineBreak":true},{"text":"And call not upon God?","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"There were they in great fear, where no fear was;","poem":1},{"lineBreak":true},{"text":"For God hath scattered the bones of him that encampeth against thee:","poem":1},{"lineBreak":true},{"text":"Thou hast put them to shame, because God hath rejected them.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Oh that the salvation of Israel were come out of Zion!","poem":1},{"lineBreak":true},{"text":"When God bringeth back the captivity of his people,","poem":1},{"lineBreak":true},{"text":"Then shall Jacob rejoice, and Israel shall be glad.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/53.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/54.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/52.json","previousChapterAudioLinks":{},"numberOfVerses":6}
