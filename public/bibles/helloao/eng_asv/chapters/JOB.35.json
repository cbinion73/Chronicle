{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"JOB","translationId":"eng_asv","name":"Job","commonName":"Job","title":"THE BOOK OF JOB","order":18,"numberOfChapters":42,"sha256":"630c4a55c5ca2770c8b02962d13c07970d5b727085d625a13fba59a7f526766e","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/JOB/1.json","lastChapterNumber":42,"lastChapterApiLink":"/api/eng_asv/JOB/42.json","totalNumberOfVerses":1070},"chapter":{"number":35,"content":[{"type":"verse","number":1,"content":["Moreover Elihu answered and said,"]},{"type":"verse","number":2,"content":[{"text":"Thinkest thou this to be thy right,","poem":1},{"lineBreak":true},{"text":"Or sayest thou, My righteousness is more than God’s,","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"That thou sayest, What advantage will it be unto thee?","poem":1},{"lineBreak":true},{"text":"And, What profit shall I have, more than if I had sinned?","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"I will answer thee,","poem":1},{"lineBreak":true},{"text":"And thy companions with thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Look unto the heavens, and see;","poem":1},{"lineBreak":true},{"text":"And behold the skies, which are higher than thou.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"If thou hast sinned, what effectest thou against him?","poem":1},{"lineBreak":true},{"text":"And if thy transgressions be multiplied, what doest thou unto him?","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"If thou be righteous, what givest thou him?","poem":1},{"lineBreak":true},{"text":"Or what receiveth he of thy hand?","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Thy wickedness may hurt a man as thou art;","poem":1},{"lineBreak":true},{"text":"And thy righteousness may profit a son of man.","poem":1}]},{"type":"line_break"},{"type":"verse","number":9,"content":[{"text":"By reason of the multitude of oppressions they cry out;","poem":1},{"lineBreak":true},{"text":"They cry for help by reason of the arm of the mighty.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"But none saith, Where is God my Maker,","poem":1},{"lineBreak":true},{"text":"Who giveth songs in the night,","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Who teacheth us more than the beasts of the earth,","poem":1},{"lineBreak":true},{"text":"And maketh us wiser than the birds of the heavens?","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"There they cry, but none giveth answer,","poem":1},{"lineBreak":true},{"text":"Because of the pride of evil men.","poem":1},{"lineBreak":true}]},{"type":"verse","number":13,"content":[{"text":"Surely God will not hear an empty cry,","poem":1},{"lineBreak":true},{"text":"Neither will the Almighty regard it.","poem":1},{"lineBreak":true}]},{"type":"verse","number":14,"content":[{"text":"How much less when thou sayest thou beholdest him not,","poem":1},{"lineBreak":true},{"text":"The cause is before him, and thou waitest for him!","poem":1},{"lineBreak":true}]},{"type":"verse","number":15,"content":[{"text":"But now, because he hath not visited in his anger,","poem":1},{"lineBreak":true},{"text":"Neither doth he greatly regard arrogance;","poem":1},{"lineBreak":true}]},{"type":"verse","number":16,"content":[{"text":"Therefore doth Job open his mouth in vanity;","poem":1},{"lineBreak":true},{"text":"He multiplieth words without knowledge.","poem":1}]},{"type":"line_break"}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/JOB/35.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/JOB/36.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/JOB/34.json","previousChapterAudioLinks":{},"numberOfVerses":16}
