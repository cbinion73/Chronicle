{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":149,"content":[{"type":"verse","number":1,"content":[{"text":"Praise ye Jehovah.","poem":1},{"lineBreak":true},{"text":"Sing unto Jehovah a new song,","poem":1},{"lineBreak":true},{"text":"And his praise in the assembly of the saints.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Let Israel rejoice in him that made him:","poem":1},{"lineBreak":true},{"text":"Let the children of Zion be joyful in their King.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Let them praise his name in the dance:","poem":1},{"lineBreak":true},{"text":"Let them sing praises unto him with timbrel and harp.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"For Jehovah taketh pleasure in his people:","poem":1},{"lineBreak":true},{"text":"He will beautify the meek with salvation.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Let the saints exult in glory:","poem":1},{"lineBreak":true},{"text":"Let them sing for joy upon their beds.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Let the high praises of God be in their mouth,","poem":1},{"lineBreak":true},{"text":"And a two-edged sword in their hand;","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"To execute vengeance upon the nations,","poem":1},{"lineBreak":true},{"text":"And punishments upon the peoples;","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"To bind their kings with chains,","poem":1},{"lineBreak":true},{"text":"And their nobles with fetters of iron;","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"To execute upon them the judgment written:","poem":1},{"lineBreak":true},{"text":"This honor have all his saints.","poem":1},{"lineBreak":true},{"text":"Praise ye Jehovah.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/149.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/150.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/148.json","previousChapterAudioLinks":{},"numberOfVerses":9}
