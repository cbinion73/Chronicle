{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":108,"content":[{"type":"hebrew_subtitle","content":["A Song, a Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"My heart is fixed, O God;","poem":1},{"lineBreak":true},{"text":"I will sing, yea, I will sing praises, even with my glory.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Awake, psaltery and harp:","poem":1},{"lineBreak":true},{"text":"I myself will awake right early.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"I will give thanks unto thee, O Jehovah, among the peoples;","poem":1},{"lineBreak":true},{"text":"And I will sing praises unto thee among the nations.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"For thy lovingkindness is great above the heavens;","poem":1},{"lineBreak":true},{"text":"And thy truth reacheth unto the skies.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Be thou exalted, O God, above the heavens,","poem":1},{"lineBreak":true},{"text":"And thy glory above all the earth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"That thy beloved may be delivered,","poem":1},{"lineBreak":true},{"text":"Save with thy right hand, and answer us.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"God hath spoken in his holiness: I will exult;","poem":1},{"lineBreak":true},{"text":"I will divide Shechem, and mete out the valley of Succoth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Gilead is mine; Manasseh is mine;","poem":1},{"lineBreak":true},{"text":"Ephraim also is the defence of my head;","poem":1},{"lineBreak":true},{"text":"Judah is my sceptre.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Moab is my washpot;","poem":1},{"lineBreak":true},{"text":"Upon Edom will I cast my shoe;","poem":1},{"lineBreak":true},{"text":"Over Philistia will I shout.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Who will bring me into the fortified city?","poem":1},{"lineBreak":true},{"text":"Who hath led me unto Edom?","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Hast not thou cast us off, O God?","poem":1},{"lineBreak":true},{"text":"And thou goest not forth, O God, with our hosts.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"Give us help against the adversary;","poem":1},{"lineBreak":true},{"text":"For vain is the help of man.","poem":1},{"lineBreak":true}]},{"type":"verse","number":13,"content":[{"text":"Through God we shall do valiantly:","poem":1},{"lineBreak":true},{"text":"For he it is that will tread down our adversaries.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/108.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/109.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/107.json","previousChapterAudioLinks":{},"numberOfVerses":13}
