{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":126,"content":[{"type":"hebrew_subtitle","content":["A Song of Ascents."]},{"type":"verse","number":1,"content":[{"text":"When Jehovah brought back those that returned to Zion,","poem":1},{"lineBreak":true},{"text":"We were like unto them that dream.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Then was our mouth filled with laughter,","poem":1},{"lineBreak":true},{"text":"And our tongue with singing:","poem":1},{"lineBreak":true},{"text":"Then said they among the nations,","poem":1},{"lineBreak":true},{"text":"Jehovah hath done great things for them.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Jehovah hath done great things for us,","poem":1},{"lineBreak":true},{"text":"Whereof we are glad.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Turn again our captivity, O Jehovah,","poem":1},{"lineBreak":true},{"text":"As the streams in the South.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"They that sow in tears shall reap in joy.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"He that goeth forth and weepeth, bearing seed for sowing,","poem":1},{"lineBreak":true},{"text":"Shall doubtless come again with joy, bringing his sheaves with him.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/126.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/127.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/125.json","previousChapterAudioLinks":{},"numberOfVerses":6}
