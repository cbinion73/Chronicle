{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":46,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm of the sons of Korah; set to Alamoth. A Song."]},{"type":"verse","number":1,"content":[{"text":"God is our refuge and strength,","poem":1},{"lineBreak":true},{"text":"A very present help in trouble.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Therefore will we not fear, though the earth do change,","poem":1},{"lineBreak":true},{"text":"And though the mountains be shaken into the heart of the seas;","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Though the waters thereof roar and be troubled,","poem":1},{"lineBreak":true},{"text":"Though the mountains tremble with the swelling thereof. [Selah","poem":1}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"There is a river, the streams whereof make glad the city of God,","poem":1},{"lineBreak":true},{"text":"The holy place of the tabernacles of the Most High.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"God is in the midst of her; she shall not be moved:","poem":1},{"lineBreak":true},{"text":"God will help her, and that right early.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"The nations raged, the kingdoms were moved:","poem":1},{"lineBreak":true},{"text":"He uttered his voice, the earth melted.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Jehovah of hosts is with us;","poem":1},{"lineBreak":true},{"text":"The God of Jacob is our refuge. [Selah","poem":1}]},{"type":"line_break"},{"type":"verse","number":8,"content":[{"text":"Come, behold the works of Jehovah,","poem":1},{"lineBreak":true},{"text":"What desolations he hath made in the earth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"He maketh wars to cease unto the end of the earth;","poem":1},{"lineBreak":true},{"text":"He breaketh the bow, and cutteth the spear in sunder;","poem":1},{"lineBreak":true},{"text":"He burneth the chariots in the fire.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Be still, and know that I am God:","poem":1},{"lineBreak":true},{"text":"I will be exalted among the nations, I will be exalted in the earth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Jehovah of hosts is with us;","poem":1},{"lineBreak":true},{"text":"The God of Jacob is our refuge. [Selah","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/46.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/47.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/45.json","previousChapterAudioLinks":{},"numberOfVerses":11}
