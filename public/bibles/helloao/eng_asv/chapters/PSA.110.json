{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":110,"content":[{"type":"hebrew_subtitle","content":["A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Jehovah saith unto my Lord, Sit thou at my right hand,","poem":1},{"lineBreak":true},{"text":"Until I make thine enemies thy footstool.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Jehovah will send forth the rod of thy strength out of Zion:","poem":1},{"lineBreak":true},{"text":"Rule thou in the midst of thine enemies.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Thy people offer themselves willingly","poem":1},{"lineBreak":true},{"text":"In the day of thy power, in holy array:","poem":1},{"lineBreak":true},{"text":"Out of the womb of the morning","poem":1},{"lineBreak":true},{"text":"Thou hast the dew of thy youth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Jehovah hath sworn, and will not repent:","poem":1},{"lineBreak":true},{"text":"Thou art a priest for ever","poem":1},{"lineBreak":true},{"text":"After the order of Melchizedek.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"The Lord at thy right hand","poem":1},{"lineBreak":true},{"text":"Will strike through kings in the day of his wrath.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"He will judge among the nations,","poem":1},{"lineBreak":true},{"text":"He will fill the places with dead bodies;","poem":1},{"lineBreak":true},{"text":"He will strike through the head in many countries.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"He will drink of the brook in the way:","poem":1},{"lineBreak":true},{"text":"Therefore will he lift up the head.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/110.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/111.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/109.json","previousChapterAudioLinks":{},"numberOfVerses":7}
