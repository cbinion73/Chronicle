{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":26,"content":[{"type":"hebrew_subtitle","content":["A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Judge me, O Jehovah, for I have walked in mine integrity:","poem":1},{"lineBreak":true},{"text":"I have trusted also in Jehovah without wavering.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Examine me, O Jehovah, and prove me;","poem":1},{"lineBreak":true},{"text":"Try my heart and my mind.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"For thy lovingkindness is before mine eyes;","poem":1},{"lineBreak":true},{"text":"And I have walked in thy truth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"I have not sat with men of falsehood;","poem":1},{"lineBreak":true},{"text":"Neither will I go in with dissemblers.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"I hate the assembly of evil-doers,","poem":1},{"lineBreak":true},{"text":"And will not sit with the wicked.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"I will wash my hands in innocency:","poem":1},{"lineBreak":true},{"text":"So will I compass thine altar, O Jehovah;","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"That I may make the voice of thanksgiving to be heard,","poem":1},{"lineBreak":true},{"text":"And tell of all thy wondrous works.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Jehovah, I love the habitation of thy house,","poem":1},{"lineBreak":true},{"text":"And the place where thy glory dwelleth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Gather not my soul with sinners,","poem":1},{"lineBreak":true},{"text":"Nor my life with men of blood;","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"In whose hands is wickedness,","poem":1},{"lineBreak":true},{"text":"And their right hand is full of bribes.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"But as for me, I will walk in mine integrity:","poem":1},{"lineBreak":true},{"text":"Redeem me, and be merciful unto me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"My foot standeth in an even place:","poem":1},{"lineBreak":true},{"text":"In the congregations will I bless Jehovah.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/26.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/27.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/25.json","previousChapterAudioLinks":{},"numberOfVerses":12}
