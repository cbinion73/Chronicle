{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":95,"content":[{"type":"verse","number":1,"content":[{"text":"Oh come, let us sing unto Jehovah;","poem":1},{"lineBreak":true},{"text":"Let us make a joyful noise to the rock of our salvation.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Let us come before his presence with thanksgiving;","poem":1},{"lineBreak":true},{"text":"Let us make a joyful noise unto him with psalms.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"For Jehovah is a great God,","poem":1},{"lineBreak":true},{"text":"And a great King above all gods.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"In his hand are the deep places of the earth;","poem":1},{"lineBreak":true},{"text":"The heights of the mountains are his also.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"The sea is his, and he made it;","poem":1},{"lineBreak":true},{"text":"And his hands formed the dry land.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Oh come, let us worship and bow down;","poem":1},{"lineBreak":true},{"text":"Let us kneel before Jehovah our Maker:","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"For he is our God,","poem":1},{"lineBreak":true},{"text":"And we are the people of his pasture, and the sheep of his hand.","poem":1},{"lineBreak":true},{"text":"To-day, oh that ye would hear his voice!","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Harden not your heart, as at Meribah,","poem":1},{"lineBreak":true},{"text":"As in the day of Massah in the wilderness;","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"When your fathers tempted me,","poem":1},{"lineBreak":true},{"text":"Proved me, and saw my work.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Forty years long was I grieved with that generation,","poem":1},{"lineBreak":true},{"text":"And said, It is a people that do err in their heart,","poem":1},{"lineBreak":true},{"text":"And they have not known my ways:","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Wherefore I sware in my wrath,","poem":1},{"lineBreak":true},{"text":"That they should not enter into my rest.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/95.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/96.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/94.json","previousChapterAudioLinks":{},"numberOfVerses":11}
