{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":115,"content":[{"type":"verse","number":1,"content":[{"text":"Not unto us, O Jehovah, not unto us,","poem":1},{"lineBreak":true},{"text":"But unto thy name give glory,","poem":1},{"lineBreak":true},{"text":"For thy lovingkindness, and for thy truth’s sake.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Wherefore should the nations say,","poem":1},{"lineBreak":true},{"text":"Where is now their God?","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"But our God is in the heavens:","poem":1},{"lineBreak":true},{"text":"He hath done whatsoever he pleased.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Their idols are silver and gold,","poem":1},{"lineBreak":true},{"text":"The work of men’s hands.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"They have mouths, but they speak not;","poem":1},{"lineBreak":true},{"text":"Eyes have they, but they see not;","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"They have ears, but they hear not;","poem":1},{"lineBreak":true},{"text":"Noses have they, but they smell not;","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"They have hands, but they handle not;","poem":1},{"lineBreak":true},{"text":"Feet have they, but they walk not;","poem":1},{"lineBreak":true},{"text":"Neither speak they through their throat.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"They that make them shall be like unto them;","poem":1},{"lineBreak":true},{"text":"Yea, every one that trusteth in them.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"O Israel, trust thou in Jehovah:","poem":1},{"lineBreak":true},{"text":"He is their help and their shield.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"O house of Aaron, trust ye in Jehovah:","poem":1},{"lineBreak":true},{"text":"He is their help and their shield.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Ye that fear Jehovah, trust in Jehovah:","poem":1},{"lineBreak":true},{"text":"He is their help and their shield.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"Jehovah hath been mindful of us; he will bless us:","poem":1},{"lineBreak":true},{"text":"He will bless the house of Israel;","poem":1},{"lineBreak":true},{"text":"He will bless the house of Aaron.","poem":1},{"lineBreak":true}]},{"type":"verse","number":13,"content":[{"text":"He will bless them that fear Jehovah,","poem":1},{"lineBreak":true},{"text":"Both small and great.","poem":1},{"lineBreak":true}]},{"type":"verse","number":14,"content":[{"text":"Jehovah increase you more and more,","poem":1},{"lineBreak":true},{"text":"You and your children.","poem":1},{"lineBreak":true}]},{"type":"verse","number":15,"content":[{"text":"Blessed are ye of Jehovah,","poem":1},{"lineBreak":true},{"text":"Who made heaven and earth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":16,"content":[{"text":"The heavens are the heavens of Jehovah;","poem":1},{"lineBreak":true},{"text":"But the earth hath he given to the children of men.","poem":1},{"lineBreak":true}]},{"type":"verse","number":17,"content":[{"text":"The dead praise not Jehovah,","poem":1},{"lineBreak":true},{"text":"Neither any that go down into silence;","poem":1},{"lineBreak":true}]},{"type":"verse","number":18,"content":[{"text":"But we will bless Jehovah","poem":1},{"lineBreak":true},{"text":"From this time forth and for evermore.","poem":1},{"lineBreak":true},{"text":"Praise ye Jehovah.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/115.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/116.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/114.json","previousChapterAudioLinks":{},"numberOfVerses":18}
