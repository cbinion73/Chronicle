{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":112,"content":[{"type":"verse","number":1,"content":[{"text":"Praise ye Jehovah.","poem":1},{"lineBreak":true},{"text":"Blessed is the man that feareth Jehovah,","poem":1},{"lineBreak":true},{"text":"That delighteth greatly in his commandments.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"His seed shall be mighty upon earth:","poem":1},{"lineBreak":true},{"text":"The generation of the upright shall be blessed.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Wealth and riches are in his house;","poem":1},{"lineBreak":true},{"text":"And his righteousness endureth for ever.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Unto the upright there ariseth light in the darkness:","poem":1},{"lineBreak":true},{"text":"He is gracious, and merciful, and righteous.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Well is it with the man that dealeth graciously and lendeth;","poem":1},{"lineBreak":true},{"text":"He shall maintain his cause in judgment.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"For he shall never be moved;","poem":1},{"lineBreak":true},{"text":"The righteous shall be had in everlasting remembrance.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"He shall not be afraid of evil tidings:","poem":1},{"lineBreak":true},{"text":"His heart is fixed, trusting in Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"His heart is established, he shall not be afraid,","poem":1},{"lineBreak":true},{"text":"Until he see his desire upon his adversaries.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"He hath dispersed, he hath given to the needy;","poem":1},{"lineBreak":true},{"text":"His righteousness endureth for ever:","poem":1},{"lineBreak":true},{"text":"His horn shall be exalted with honor.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"The wicked shall see it, and be grieved;","poem":1},{"lineBreak":true},{"text":"He shall gnash with his teeth, and melt away:","poem":1},{"lineBreak":true},{"text":"The desire of the wicked shall perish.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/112.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/113.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/111.json","previousChapterAudioLinks":{},"numberOfVerses":10}
