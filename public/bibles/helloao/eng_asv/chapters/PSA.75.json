{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":75,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; set to Al-tashheth. A Psalm of Asaph, a Song."]},{"type":"verse","number":1,"content":[{"text":"We give thanks unto thee, O God;","poem":1},{"lineBreak":true},{"text":"We give thanks, for thy name is near:","poem":1},{"lineBreak":true},{"text":"Men tell of thy wondrous works.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"When I shall find the set time,","poem":1},{"lineBreak":true},{"text":"I will judge uprightly.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"The earth and all the inhabitants thereof are dissolved:","poem":1},{"lineBreak":true},{"text":"I have set up the pillars of it. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"I said unto the arrogant, Deal not arrogantly;","poem":1},{"lineBreak":true},{"text":"And to the wicked, Lift not up the horn:","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Lift not up your horn on high;","poem":1},{"lineBreak":true},{"text":"Speak not with a stiff neck.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"For neither from the east, nor from the west,","poem":1},{"lineBreak":true},{"text":"Nor yet from the south, cometh lifting up.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"But God is the judge:","poem":1},{"lineBreak":true},{"text":"He putteth down one, and lifteth up another.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"For in the hand of Jehovah there is a cup, and the wine foameth;","poem":1},{"lineBreak":true},{"text":"It is full of mixture, and he poureth out of the same:","poem":1},{"lineBreak":true},{"text":"Surely the dregs thereof, all the wicked of the earth shall drain them, and drink them.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"But I will declare for ever,","poem":1},{"lineBreak":true},{"text":"I will sing praises to the God of Jacob.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"All the horns of the wicked also will I cut off;","poem":1},{"lineBreak":true},{"text":"But the horns of the righteous shall be lifted up.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/75.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/76.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/74.json","previousChapterAudioLinks":{},"numberOfVerses":10}
