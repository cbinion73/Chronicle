{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":99,"content":[{"type":"verse","number":1,"content":[{"text":"Jehovah reigneth; let the peoples tremble:","poem":1},{"lineBreak":true},{"text":"He sitteth above the cherubim; let the earth be moved.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Jehovah is great in Zion;","poem":1},{"lineBreak":true},{"text":"And he is high above all the peoples.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Let them praise thy great and terrible name:","poem":1},{"lineBreak":true},{"text":"Holy is he.","poem":1}]},{"type":"line_break"},{"type":"verse","number":4,"content":[{"text":"The king’s strength also loveth justice;","poem":1},{"lineBreak":true},{"text":"Thou dost establish equity;","poem":1},{"lineBreak":true},{"text":"Thou executest justice and righteousness in Jacob.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Exalt ye Jehovah our God,","poem":1},{"lineBreak":true},{"text":"And worship at his footstool:","poem":1},{"lineBreak":true},{"text":"Holy is he.","poem":1}]},{"type":"line_break"},{"type":"verse","number":6,"content":[{"text":"Moses and Aaron among his priests,","poem":1},{"lineBreak":true},{"text":"And Samuel among them that call upon his name;","poem":1},{"lineBreak":true},{"text":"They called upon Jehovah, and he answered them.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"He spake unto them in the pillar of cloud:","poem":1},{"lineBreak":true},{"text":"They kept his testimonies,","poem":1},{"lineBreak":true},{"text":"And the statute that he gave them.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Thou answeredst them, O Jehovah our God:","poem":1},{"lineBreak":true},{"text":"Thou wast a God that forgavest them,","poem":1},{"lineBreak":true},{"text":"Though thou tookest vengeance of their doings.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Exalt ye Jehovah our God,","poem":1},{"lineBreak":true},{"text":"And worship at his holy hill;","poem":1},{"lineBreak":true},{"text":"For Jehovah our God is holy.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/99.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/100.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/98.json","previousChapterAudioLinks":{},"numberOfVerses":9}
