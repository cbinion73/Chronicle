{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":146,"content":[{"type":"verse","number":1,"content":[{"text":"Praise ye Jehovah.","poem":1},{"lineBreak":true},{"text":"Praise Jehovah, O my soul.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"While I live will I praise Jehovah:","poem":1},{"lineBreak":true},{"text":"I will sing praises unto my God while I have any being.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Put not your trust in princes,","poem":1},{"lineBreak":true},{"text":"Nor in the son of man, in whom there is no help.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"His breath goeth forth, he returneth to his earth;","poem":1},{"lineBreak":true},{"text":"In that very day his thoughts perish.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Happy is he that hath the God of Jacob for his help,","poem":1},{"lineBreak":true},{"text":"Whose hope is in Jehovah his God:","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Who made heaven and earth,","poem":1},{"lineBreak":true},{"text":"The sea, and all that in them is;","poem":1},{"lineBreak":true},{"text":"Who keepeth truth for ever;","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Who executeth justice for the oppressed;","poem":1},{"lineBreak":true},{"text":"Who giveth food to the hungry.","poem":1},{"lineBreak":true},{"text":"Jehovah looseth the prisoners;","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Jehovah openeth the eyes of the blind;","poem":1},{"lineBreak":true},{"text":"Jehovah raiseth up them that are bowed down;","poem":1},{"lineBreak":true},{"text":"Jehovah loveth the righteous;","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Jehovah preserveth the sojourners;","poem":1},{"lineBreak":true},{"text":"He upholdeth the fatherless and widow;","poem":1},{"lineBreak":true},{"text":"But the way of the wicked he turneth upside down.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Jehovah will reign for ever,","poem":1},{"lineBreak":true},{"text":"Thy God, O Zion, unto all generations.","poem":1},{"lineBreak":true},{"text":"Praise ye Jehovah.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/146.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/147.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/145.json","previousChapterAudioLinks":{},"numberOfVerses":10}
