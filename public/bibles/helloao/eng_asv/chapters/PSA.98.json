{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":98,"content":[{"type":"hebrew_subtitle","content":["A Psalm."]},{"type":"verse","number":1,"content":[{"text":"Oh sing unto Jehovah a new song;","poem":1},{"lineBreak":true},{"text":"For he hath done marvellous things:","poem":1},{"lineBreak":true},{"text":"His right hand, and his holy arm, hath wrought salvation for him.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Jehovah hath made known his salvation:","poem":1},{"lineBreak":true},{"text":"His righteousness hath he openly showed in the sight of the nations.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"He hath remembered his lovingkindness and his faithfulness toward the house of Israel:","poem":1},{"lineBreak":true},{"text":"All the ends of the earth have seen the salvation of our God.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Make a joyful noise unto Jehovah, all the earth:","poem":1},{"lineBreak":true},{"text":"Break forth and sing for joy, yea, sing praises.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Sing praises unto Jehovah with the harp;","poem":1},{"lineBreak":true},{"text":"With the harp and the voice of melody.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"With trumpets and sound of cornet","poem":1},{"lineBreak":true},{"text":"Make a joyful noise before the King, Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Let the sea roar, and the fulness thereof;","poem":1},{"lineBreak":true},{"text":"The world, and they that dwell therein;","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Let the floods clap their hands;","poem":1},{"lineBreak":true},{"text":"Let the hills sing for joy together","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Before Jehovah; for he cometh to judge the earth:","poem":1},{"lineBreak":true},{"text":"He will judge the world with righteousness,","poem":1},{"lineBreak":true},{"text":"And the peoples with equity.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/98.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/99.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/97.json","previousChapterAudioLinks":{},"numberOfVerses":9}
