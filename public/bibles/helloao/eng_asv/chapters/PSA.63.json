{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":63,"content":[{"type":"hebrew_subtitle","content":["A Psalm of David, when he was in the wilderness of Judah."]},{"type":"verse","number":1,"content":[{"text":"O God, thou art my God; earnestly will I seek thee:","poem":1},{"lineBreak":true},{"text":"My soul thirsteth for thee, my flesh longeth for thee,","poem":1},{"lineBreak":true},{"text":"In a dry and weary land, where no water is.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"So have I looked upon thee in the sanctuary,","poem":1},{"lineBreak":true},{"text":"To see thy power and thy glory.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Because thy lovingkindness is better than life,","poem":1},{"lineBreak":true},{"text":"My lips shall praise thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"So will I bless thee while I live:","poem":1},{"lineBreak":true},{"text":"I will lift up my hands in thy name.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"My soul shall be satisfied as with marrow and fatness;","poem":1},{"lineBreak":true},{"text":"And my mouth shall praise thee with joyful lips;","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"When I remember thee upon my bed,","poem":1},{"lineBreak":true},{"text":"And meditate on thee in the night-watches.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"For thou hast been my help,","poem":1},{"lineBreak":true},{"text":"And in the shadow of thy wings will I rejoice.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"My soul followeth hard after thee:","poem":1},{"lineBreak":true},{"text":"Thy right hand upholdeth me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"But those that seek my soul, to destroy it,","poem":1},{"lineBreak":true},{"text":"Shall go into the lower parts of the earth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"They shall be given over to the power of the sword:","poem":1},{"lineBreak":true},{"text":"They shall be a portion for foxes.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"But the king shall rejoice in God:","poem":1},{"lineBreak":true},{"text":"Every one that sweareth by him shall glory;","poem":1},{"lineBreak":true},{"text":"For the mouth of them that speak lies shall be stopped.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/63.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/64.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/62.json","previousChapterAudioLinks":{},"numberOfVerses":11}
