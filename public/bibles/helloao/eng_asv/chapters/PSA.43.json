{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":43,"content":[{"type":"verse","number":1,"content":[{"text":"Judge me, O God, and plead my cause against an ungodly nation:","poem":1},{"lineBreak":true},{"text":"Oh deliver me from the deceitful and unjust man.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"For thou art the God of my strength; why hast thou cast me off?","poem":1},{"lineBreak":true},{"text":"Why go I mourning because of the oppression of the enemy?","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Oh send out thy light and thy truth; let them lead me:","poem":1},{"lineBreak":true},{"text":"Let them bring me unto thy holy hill,","poem":1},{"lineBreak":true},{"text":"And to thy tabernacles.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Then will I go unto the altar of God,","poem":1},{"lineBreak":true},{"text":"Unto God my exceeding joy;","poem":1},{"lineBreak":true},{"text":"And upon the harp will I praise thee, O God, my God.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Why art thou cast down, O my soul?","poem":1},{"lineBreak":true},{"text":"And why art thou disquieted within me?","poem":1},{"lineBreak":true},{"text":"Hope thou in God; for I shall yet praise him,","poem":1},{"lineBreak":true},{"text":"Who is the help of my countenance, and my God.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/43.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/44.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/42.json","previousChapterAudioLinks":{},"numberOfVerses":5}
