{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":120,"content":[{"type":"hebrew_subtitle","content":["A Song of Ascents."]},{"type":"verse","number":1,"content":[{"text":"In my distress I cried unto Jehovah,","poem":1},{"lineBreak":true},{"text":"And he answered me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Deliver my soul, O Jehovah, from lying lips,","poem":1},{"lineBreak":true},{"text":"And from a deceitful tongue.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"What shall be given unto thee, and what shall be done more unto thee,","poem":1},{"lineBreak":true},{"text":"Thou deceitful tongue?","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Sharp arrows of the mighty,","poem":1},{"lineBreak":true},{"text":"With coals of juniper.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Woe is me, that I sojourn in Meshech,","poem":1},{"lineBreak":true},{"text":"That I dwell among the tents of Kedar!","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"My soul hath long had her dwelling","poem":1},{"lineBreak":true},{"text":"With him that hateth peace.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"I am for peace:","poem":1},{"lineBreak":true},{"text":"But when I speak, they are for war.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/120.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/121.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/119.json","previousChapterAudioLinks":{},"numberOfVerses":7}
