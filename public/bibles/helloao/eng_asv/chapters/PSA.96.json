{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":96,"content":[{"type":"verse","number":1,"content":[{"text":"Oh sing unto Jehovah a new song:","poem":1},{"lineBreak":true},{"text":"Sing unto Jehovah, all the earth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Sing unto Jehovah, bless his name;","poem":1},{"lineBreak":true},{"text":"Show forth his salvation from day to day.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Declare his glory among the nations,","poem":1},{"lineBreak":true},{"text":"His marvellous works among all the peoples.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"For great is Jehovah, and greatly to be praised:","poem":1},{"lineBreak":true},{"text":"He is to be feared above all gods.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"For all the gods of the peoples are idols;","poem":1},{"lineBreak":true},{"text":"But Jehovah made the heavens.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Honor and majesty are before him:","poem":1},{"lineBreak":true},{"text":"Strength and beauty are in his sanctuary.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Ascribe unto Jehovah, ye kindreds of the peoples,","poem":1},{"lineBreak":true},{"text":"Ascribe unto Jehovah glory and strength.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Ascribe unto Jehovah the glory due unto his name:","poem":1},{"lineBreak":true},{"text":"Bring an offering, and come into his courts.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Oh worship Jehovah in holy array:","poem":1},{"lineBreak":true},{"text":"Tremble before him, all the earth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Say among the nations, Jehovah reigneth:","poem":1},{"lineBreak":true},{"text":"The world also is established that it cannot be moved:","poem":1},{"lineBreak":true},{"text":"He will judge the peoples with equity.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Let the heavens be glad, and let the earth rejoice;","poem":1},{"lineBreak":true},{"text":"Let the sea roar, and the fulness thereof;","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"Let the field exult, and all that is therein;","poem":1},{"lineBreak":true},{"text":"Then shall all the trees of the wood sing for joy","poem":1},{"lineBreak":true}]},{"type":"verse","number":13,"content":[{"text":"Before Jehovah; for he cometh,","poem":1},{"lineBreak":true},{"text":"For he cometh to judge the earth:","poem":1},{"lineBreak":true},{"text":"He will judge the world with righteousness,","poem":1},{"lineBreak":true},{"text":"And the peoples with his truth.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/96.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/97.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/95.json","previousChapterAudioLinks":{},"numberOfVerses":13}
