{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":132,"content":[{"type":"hebrew_subtitle","content":["A Song of Ascents."]},{"type":"verse","number":1,"content":[{"text":"Jehovah, remember for David","poem":1},{"lineBreak":true},{"text":"All his affliction;","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"How he sware unto Jehovah,","poem":1},{"lineBreak":true},{"text":"And vowed unto the Mighty One of Jacob:","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Surely I will not come into the tabernacle of my house,","poem":1},{"lineBreak":true},{"text":"Nor go up into my bed;","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"I will not give sleep to mine eyes,","poem":1},{"lineBreak":true},{"text":"Or slumber to mine eyelids;","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Until I find out a place for Jehovah,","poem":1},{"lineBreak":true},{"text":"A tabernacle for the Mighty One of Jacob.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Lo, we heard of it in Ephrathah:","poem":1},{"lineBreak":true},{"text":"We found it in the field of the wood.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"We will go into his tabernacles;","poem":1},{"lineBreak":true},{"text":"We will worship at his footstool.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Arise, O Jehovah, into thy resting-place;","poem":1},{"lineBreak":true},{"text":"Thou, and the ark of thy strength.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Let thy priests be clothed with righteousness;","poem":1},{"lineBreak":true},{"text":"And let thy saints shout for joy.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"For thy servant David’s sake","poem":1},{"lineBreak":true},{"text":"Turn not away the face of thine anointed.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Jehovah hath sworn unto David in truth;","poem":1},{"lineBreak":true},{"text":"He will not turn from it:","poem":1},{"lineBreak":true},{"text":"Of the fruit of thy body will I set upon thy throne.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"If thy children will keep my covenant","poem":1},{"lineBreak":true},{"text":"And my testimony that I shall teach them,","poem":1},{"lineBreak":true},{"text":"Their children also shall sit upon thy throne for evermore.","poem":1},{"lineBreak":true}]},{"type":"verse","number":13,"content":[{"text":"For Jehovah hath chosen Zion;","poem":1},{"lineBreak":true},{"text":"He hath desired it for his habitation.","poem":1},{"lineBreak":true}]},{"type":"verse","number":14,"content":[{"text":"This is my resting-place for ever:","poem":1},{"lineBreak":true},{"text":"Here will I dwell; for I have desired it.","poem":1},{"lineBreak":true}]},{"type":"verse","number":15,"content":[{"text":"I will abundantly bless her provision:","poem":1},{"lineBreak":true},{"text":"I will satisfy her poor with bread.","poem":1},{"lineBreak":true}]},{"type":"verse","number":16,"content":[{"text":"Her priests also will I clothe with salvation;","poem":1},{"lineBreak":true},{"text":"And her saints shall shout aloud for joy.","poem":1},{"lineBreak":true}]},{"type":"verse","number":17,"content":[{"text":"There will I make the horn of David to bud:","poem":1},{"lineBreak":true},{"text":"I have ordained a lamp for mine anointed.","poem":1},{"lineBreak":true}]},{"type":"verse","number":18,"content":[{"text":"His enemies will I clothe with shame;","poem":1},{"lineBreak":true},{"text":"But upon himself shall his crown flourish.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/132.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/133.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/131.json","previousChapterAudioLinks":{},"numberOfVerses":18}
