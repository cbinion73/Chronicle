{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":13,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"How long, O Jehovah? wilt thou forget me for ever?","poem":1},{"lineBreak":true},{"text":"How long wilt thou hide thy face from me?","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"How long shall I take counsel in my soul,","poem":1},{"lineBreak":true},{"text":"Having sorrow in my heart all the day?","poem":1},{"lineBreak":true},{"text":"How long shall mine enemy be exalted over me?","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Consider and answer me, O Jehovah my God:","poem":1},{"lineBreak":true},{"text":"Lighten mine eyes, lest I sleep the sleep of death;","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Lest mine enemy say, I have prevailed against him;","poem":1},{"lineBreak":true},{"text":"Lest mine adversaries rejoice when I am moved.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"But I have trusted in thy lovingkindness;","poem":1},{"lineBreak":true},{"text":"My heart shall rejoice in thy salvation.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"I will sing unto Jehovah,","poem":1},{"lineBreak":true},{"text":"Because he hath dealt bountifully with me.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/13.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/14.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/12.json","previousChapterAudioLinks":{},"numberOfVerses":6}
