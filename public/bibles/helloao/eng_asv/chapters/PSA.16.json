{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":16,"content":[{"type":"hebrew_subtitle","content":["Michtam of David."]},{"type":"verse","number":1,"content":[{"text":"Preserve me, O God; for in thee do I take refuge.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"O my soul, thou hast said unto Jehovah, Thou art my Lord:","poem":1},{"lineBreak":true},{"text":"I have no good beyond thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"As for the saints that are in the earth,","poem":1},{"lineBreak":true},{"text":"They are the excellent in whom is all my delight.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Their sorrows shall be multiplied that give gifts for another god:","poem":1},{"lineBreak":true},{"text":"Their drink-offerings of blood will I not offer,","poem":1},{"lineBreak":true},{"text":"Nor take their names upon my lips.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Jehovah is the portion of mine inheritance and of my cup:","poem":1},{"lineBreak":true},{"text":"Thou maintainest my lot.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"The lines are fallen unto me in pleasant places;","poem":1},{"lineBreak":true},{"text":"Yea, I have a goodly heritage.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"I will bless Jehovah, who hath given me counsel;","poem":1},{"lineBreak":true},{"text":"Yea, my heart instructeth me in the night seasons.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"I have set Jehovah always before me:","poem":1},{"lineBreak":true},{"text":"Because he is at my right hand, I shall not be moved.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Therefore my heart is glad, and my glory rejoiceth:","poem":1},{"lineBreak":true},{"text":"My flesh also shall dwell in safety.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"For thou wilt not leave my soul to Sheol;","poem":1},{"lineBreak":true},{"text":"Neither wilt thou suffer thy holy one to see corruption.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Thou wilt show me the path of life:","poem":1},{"lineBreak":true},{"text":"In thy presence is fulness of joy;","poem":1},{"lineBreak":true},{"text":"In thy right hand there are pleasures for evermore.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/16.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/17.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/15.json","previousChapterAudioLinks":{},"numberOfVerses":11}
