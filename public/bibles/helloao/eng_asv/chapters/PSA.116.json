{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":116,"content":[{"type":"verse","number":1,"content":[{"text":"I love Jehovah, because he heareth","poem":1},{"lineBreak":true},{"text":"My voice and my supplications.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Because he hath inclined his ear unto me,","poem":1},{"lineBreak":true},{"text":"Therefore will I call upon him as long as I live.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"The cords of death compassed me,","poem":1},{"lineBreak":true},{"text":"And the pains of Sheol gat hold upon me:","poem":1},{"lineBreak":true},{"text":"I found trouble and sorrow.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Then called I upon the name of Jehovah:","poem":1},{"lineBreak":true},{"text":"O Jehovah, I beseech thee, deliver my soul.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Gracious is Jehovah, and righteous;","poem":1},{"lineBreak":true},{"text":"Yea, our God is merciful.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Jehovah preserveth the simple:","poem":1},{"lineBreak":true},{"text":"I was brought low, and he saved me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Return unto thy rest, O my soul;","poem":1},{"lineBreak":true},{"text":"For Jehovah hath dealt bountifully with thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"For thou hast delivered my soul from death,","poem":1},{"lineBreak":true},{"text":"Mine eyes from tears,","poem":1},{"lineBreak":true},{"text":"And my feet from falling.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"I will walk before Jehovah","poem":1},{"lineBreak":true},{"text":"In the land of the living.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"I believe, for I will speak:","poem":1},{"lineBreak":true},{"text":"I was greatly afflicted:","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"I said in my haste,","poem":1},{"lineBreak":true},{"text":"All men are liars.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"What shall I render unto Jehovah","poem":1},{"lineBreak":true},{"text":"For all his benefits toward me?","poem":1},{"lineBreak":true}]},{"type":"verse","number":13,"content":[{"text":"I will take the cup of salvation,","poem":1},{"lineBreak":true},{"text":"And call upon the name of Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":14,"content":[{"text":"I will pay my vows unto Jehovah,","poem":1},{"lineBreak":true},{"text":"Yea, in the presence of all his people.","poem":1},{"lineBreak":true}]},{"type":"verse","number":15,"content":[{"text":"Precious in the sight of Jehovah","poem":1},{"lineBreak":true},{"text":"Is the death of his saints.","poem":1},{"lineBreak":true}]},{"type":"verse","number":16,"content":[{"text":"O Jehovah, truly I am thy servant:","poem":1},{"lineBreak":true},{"text":"I am thy servant, the son of thy handmaid;","poem":1},{"lineBreak":true},{"text":"Thou hast loosed my bonds.","poem":1},{"lineBreak":true}]},{"type":"verse","number":17,"content":[{"text":"I will offer to thee the sacrifice of thanksgiving,","poem":1},{"lineBreak":true},{"text":"And will call upon the name of Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":18,"content":[{"text":"I will pay my vows unto Jehovah,","poem":1},{"lineBreak":true},{"text":"Yea, in the presence of all his people,","poem":1},{"lineBreak":true}]},{"type":"verse","number":19,"content":[{"text":"In the courts of Jehovah’s house,","poem":1},{"lineBreak":true},{"text":"In the midst of thee, O Jerusalem.","poem":1},{"lineBreak":true},{"text":"Praise ye Jehovah.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/116.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/117.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/115.json","previousChapterAudioLinks":{},"numberOfVerses":19}
