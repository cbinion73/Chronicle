{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":143,"content":[{"type":"hebrew_subtitle","content":["A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Hear my prayer, O Jehovah; give ear to my supplications:","poem":1},{"lineBreak":true},{"text":"In thy faithfulness answer me, and in thy righteousness.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"And enter not into judgment with thy servant;","poem":1},{"lineBreak":true},{"text":"For in thy sight no man living is righteous.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"For the enemy hath persecuted my soul;","poem":1},{"lineBreak":true},{"text":"He hath smitten my life down to the ground:","poem":1},{"lineBreak":true},{"text":"He hath made me to dwell in dark places, as those that have been long dead.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Therefore is my spirit overwhelmed within me;","poem":1},{"lineBreak":true},{"text":"My heart within me is desolate.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"I remember the days of old;","poem":1},{"lineBreak":true},{"text":"I meditate on all thy doings;","poem":1},{"lineBreak":true},{"text":"I muse on the work of thy hands.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"I spread forth my hands unto thee:","poem":1},{"lineBreak":true},{"text":"My soul thirsteth after thee, as a weary land. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Make haste to answer me, O Jehovah; my spirit faileth:","poem":1},{"lineBreak":true},{"text":"Hide not thy face from me,","poem":1},{"lineBreak":true},{"text":"Lest I become like them that go down into the pit.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Cause me to hear thy lovingkindness in the morning;","poem":1},{"lineBreak":true},{"text":"For in thee do I trust:","poem":1},{"lineBreak":true},{"text":"Cause me to know the way wherein I should walk;","poem":1},{"lineBreak":true},{"text":"For I lift up my soul unto thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Deliver me, O Jehovah, from mine enemies:","poem":1},{"lineBreak":true},{"text":"I flee unto thee to hide me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Teach me to do thy will;","poem":1},{"lineBreak":true},{"text":"For thou art my God:","poem":1},{"lineBreak":true},{"text":"Thy Spirit is good;","poem":1},{"lineBreak":true},{"text":"Lead me in the land of uprightness.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Quicken me, O Jehovah, for thy name’s sake:","poem":1},{"lineBreak":true},{"text":"In thy righteousness bring my soul out of trouble.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"And in thy lovingkindness cut off mine enemies,","poem":1},{"lineBreak":true},{"text":"And destroy all them that afflict my soul;","poem":1},{"lineBreak":true},{"text":"For I am thy servant.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/143.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/144.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/142.json","previousChapterAudioLinks":{},"numberOfVerses":12}
