{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":137,"content":[{"type":"verse","number":1,"content":[{"text":"By the rivers of Babylon,","poem":1},{"lineBreak":true},{"text":"There we sat down, yea, we wept,","poem":1},{"lineBreak":true},{"text":"When we remembered Zion.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Upon the willows in the midst thereof","poem":1},{"lineBreak":true},{"text":"We hanged up our harps.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"For there they that led us captive required of us songs,","poem":1},{"lineBreak":true},{"text":"And they that wasted us required of us mirth, saying,","poem":1},{"lineBreak":true},{"text":"Sing us one of the songs of Zion.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"How shall we sing Jehovah’s song","poem":1},{"lineBreak":true},{"text":"In a foreign land?","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"If I forget thee, O Jerusalem,","poem":1},{"lineBreak":true},{"text":"Let my right hand forget her skill.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Let my tongue cleave to the roof of my mouth,","poem":1},{"lineBreak":true},{"text":"If I remember thee not;","poem":1},{"lineBreak":true},{"text":"If I prefer not Jerusalem","poem":1},{"lineBreak":true},{"text":"Above my chief joy.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Remember, O Jehovah, against the children of Edom","poem":1},{"lineBreak":true},{"text":"The day of Jerusalem;","poem":1},{"lineBreak":true},{"text":"Who said, Rase it, rase it,","poem":1},{"lineBreak":true},{"text":"Even to the foundation thereof.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"O daughter of Babylon, that art to be destroyed,","poem":1},{"lineBreak":true},{"text":"Happy shall he be, that rewardeth thee","poem":1},{"lineBreak":true},{"text":"As thou hast served us.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Happy shall he be, that taketh and dasheth thy little ones","poem":1},{"lineBreak":true},{"text":"Against the rock.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/137.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/138.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/136.json","previousChapterAudioLinks":{},"numberOfVerses":9}
