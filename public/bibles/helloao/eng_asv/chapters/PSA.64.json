{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":64,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Hear my voice, O God, in my complaint:","poem":1},{"lineBreak":true},{"text":"Preserve my life from fear of the enemy.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Hide me from the secret counsel of evil-doers,","poem":1},{"lineBreak":true},{"text":"From the tumult of the workers of iniquity;","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Who have whet their tongue like a sword,","poem":1},{"lineBreak":true},{"text":"And have aimed their arrows, even bitter words,","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"That they may shoot in secret places at the perfect:","poem":1},{"lineBreak":true},{"text":"Suddenly do they shoot at him, and fear not.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"They encourage themselves in an evil purpose;","poem":1},{"lineBreak":true},{"text":"They commune of laying snares privily;","poem":1},{"lineBreak":true},{"text":"They say, Who will see them?","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"They search out iniquities;","poem":1},{"lineBreak":true},{"text":"We have accomplished, say they, a diligent search:","poem":1},{"lineBreak":true},{"text":"And the inward thought and the heart of every one is deep.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"But God will shoot at them;","poem":1},{"lineBreak":true},{"text":"With an arrow suddenly shall they be wounded.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"So they shall be made to stumble, their own tongue being against them:","poem":1},{"lineBreak":true},{"text":"All that see them shall wag the head.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"And all men shall fear;","poem":1},{"lineBreak":true},{"text":"And they shall declare the work of God,","poem":1},{"lineBreak":true},{"text":"And shall wisely consider of his doing.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"The righteous shall be glad in Jehovah, and shall take refuge in him;","poem":1},{"lineBreak":true},{"text":"And all the upright in heart shall glory.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/64.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/65.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/63.json","previousChapterAudioLinks":{},"numberOfVerses":10}
