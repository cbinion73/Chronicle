{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":56,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; set to Jonath elem rehokim. A Psalm of David. Michtam; when the Philistines took him in Gath."]},{"type":"verse","number":1,"content":[{"text":"Be merciful unto me, O God; for man would swallow me up:","poem":1},{"lineBreak":true},{"text":"All the day long he fighting oppresseth me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Mine enemies would swallow me up all the day long;","poem":1},{"lineBreak":true},{"text":"For they are many that fight proudly against me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"What time I am afraid,","poem":1},{"lineBreak":true},{"text":"I will put my trust in thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"In God (I will praise his word),","poem":1},{"lineBreak":true},{"text":"In God have I put my trust, I will not be afraid;","poem":1},{"lineBreak":true},{"text":"What can flesh do unto me?","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"All the day long they wrest my words:","poem":1},{"lineBreak":true},{"text":"All their thoughts are against me for evil.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"They gather themselves together, they hide themselves,","poem":1},{"lineBreak":true},{"text":"They mark my steps,","poem":1},{"lineBreak":true},{"text":"Even as they have waited for my soul.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Shall they escape by iniquity?","poem":1},{"lineBreak":true},{"text":"In anger cast down the peoples, O God.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Thou numberest my wanderings:","poem":1},{"lineBreak":true},{"text":"Put thou my tears into thy bottle;","poem":1},{"lineBreak":true},{"text":"Are they not in thy book?","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Then shall mine enemies turn back in the day that I call:","poem":1},{"lineBreak":true},{"text":"This I know, that God is for me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"In God (I will praise his word),","poem":1},{"lineBreak":true},{"text":"In Jehovah (I will praise his word),","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"In God have I put my trust, I will not be afraid;","poem":1},{"lineBreak":true},{"text":"What can man do unto me?","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"Thy vows are upon me, O God:","poem":1},{"lineBreak":true},{"text":"I will render thank-offerings unto thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":13,"content":[{"text":"For thou hast delivered my soul from death:","poem":1},{"lineBreak":true},{"text":"Hast thou not delivered my feet from falling,","poem":1},{"lineBreak":true},{"text":"That I may walk before God","poem":1},{"lineBreak":true},{"text":"In the light of the living?","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/56.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/57.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/55.json","previousChapterAudioLinks":{},"numberOfVerses":13}
