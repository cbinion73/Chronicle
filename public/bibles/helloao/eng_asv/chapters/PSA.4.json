{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":4,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; on stringed instruments. A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Answer me when I call, O God of my righteousness;","poem":1},{"lineBreak":true},{"text":"Thou hast set me at large when I was in distress:","poem":1},{"lineBreak":true},{"text":"Have mercy upon me, and hear my prayer.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"O ye sons of men, how long shall my glory be turned into dishonor?","poem":1},{"lineBreak":true},{"text":"How long will ye love vanity, and seek after falsehood? [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"But know that Jehovah hath set apart for himself him that is godly:","poem":1},{"lineBreak":true},{"text":"Jehovah will hear when I call unto him.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Stand in awe, and sin not:","poem":1},{"lineBreak":true},{"text":"Commune with your own heart upon your bed, and be still. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Offer the sacrifices of righteousness,","poem":1},{"lineBreak":true},{"text":"And put your trust in Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Many there are that say, Who will show us any good?","poem":1},{"lineBreak":true},{"text":"Jehovah, lift thou up the light of thy countenance upon us.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Thou hast put gladness in my heart,","poem":1},{"lineBreak":true},{"text":"More than they have when their grain and their new wine are increased.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"In peace will I both lay me down and sleep;","poem":1},{"lineBreak":true},{"text":"For thou, Jehovah, alone makest me dwell in safety.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/4.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/5.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/3.json","previousChapterAudioLinks":{},"numberOfVerses":8}
