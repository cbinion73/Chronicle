{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":85,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm of the sons of Korah."]},{"type":"verse","number":1,"content":[{"text":"Jehovah, thou hast been favorable unto thy land;","poem":1},{"lineBreak":true},{"text":"Thou hast brought back the captivity of Jacob.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Thou hast forgiven the iniquity of thy people;","poem":1},{"lineBreak":true},{"text":"Thou hast covered all their sin. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Thou hast taken away all thy wrath;","poem":1},{"lineBreak":true},{"text":"Thou hast turned thyself from the fierceness of thine anger.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Turn us, O God of our salvation,","poem":1},{"lineBreak":true},{"text":"And cause thine indignation toward us to cease.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Wilt thou be angry with us for ever?","poem":1},{"lineBreak":true},{"text":"Wilt thou draw out thine anger to all generations?","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Wilt thou not quicken us again,","poem":1},{"lineBreak":true},{"text":"That thy people may rejoice in thee?","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Show us thy lovingkindness, O Jehovah,","poem":1},{"lineBreak":true},{"text":"And grant us thy salvation.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"I will hear what God Jehovah will speak;","poem":1},{"lineBreak":true},{"text":"For he will speak peace unto his people, and to his saints:","poem":1},{"lineBreak":true},{"text":"But let them not turn again to folly.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Surely his salvation is nigh them that fear him,","poem":1},{"lineBreak":true},{"text":"That glory may dwell in our land.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Mercy and truth are met together;","poem":1},{"lineBreak":true},{"text":"Righteousness and peace have kissed each other.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Truth springeth out of the earth;","poem":1},{"lineBreak":true},{"text":"And righteousness hath looked down from heaven.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"Yea, Jehovah will give that which is good;","poem":1},{"lineBreak":true},{"text":"And our land shall yield its increase.","poem":1},{"lineBreak":true}]},{"type":"verse","number":13,"content":[{"text":"Righteousness shall go before him,","poem":1},{"lineBreak":true},{"text":"And shall make his footsteps a way to walk in.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/85.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/86.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/84.json","previousChapterAudioLinks":{},"numberOfVerses":13}
