{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":76,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; on stringed instruments. A Psalm of Asaph, a Song."]},{"type":"verse","number":1,"content":[{"text":"In Judah is God known:","poem":1},{"lineBreak":true},{"text":"His name is great in Israel.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"In Salem also is his tabernacle,","poem":1},{"lineBreak":true},{"text":"And his dwelling-place in Zion.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"There he brake the arrows of the bow;","poem":1},{"lineBreak":true},{"text":"The shield, and the sword, and the battle. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Glorious art thou and excellent,","poem":1},{"lineBreak":true},{"text":"From the mountains of prey.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"The stouthearted are made a spoil,","poem":1},{"lineBreak":true},{"text":"They have slept their sleep;","poem":1},{"lineBreak":true},{"text":"And none of the men of might have found their hands.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"At thy rebuke, O God of Jacob,","poem":1},{"lineBreak":true},{"text":"Both chariot and horse are cast into a dead sleep.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Thou, even thou, art to be feared;","poem":1},{"lineBreak":true},{"text":"And who may stand in thy sight when once thou art angry?","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Thou didst cause sentence to be heard from heaven;","poem":1},{"lineBreak":true},{"text":"The earth feared, and was still,","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"When God arose to judgment,","poem":1},{"lineBreak":true},{"text":"To save all the meek of the earth. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"Surely the wrath of man shall praise thee:","poem":1},{"lineBreak":true},{"text":"The residue of wrath shalt thou gird upon thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":11,"content":[{"text":"Vow, and pay unto Jehovah your God:","poem":1},{"lineBreak":true},{"text":"Let all that are round about him bring presents unto him that ought to be feared.","poem":1},{"lineBreak":true}]},{"type":"verse","number":12,"content":[{"text":"He will cut off the spirit of princes:","poem":1},{"lineBreak":true},{"text":"He is terrible to the kings of the earth.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/76.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/77.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/75.json","previousChapterAudioLinks":{},"numberOfVerses":12}
