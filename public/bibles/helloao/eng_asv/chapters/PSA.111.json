{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":111,"content":[{"type":"verse","number":1,"content":[{"text":"Praise ye Jehovah.","poem":1},{"lineBreak":true},{"text":"I will give thanks unto Jehovah with my whole heart,","poem":1},{"lineBreak":true},{"text":"In the council of the upright, and in the congregation.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"The works of Jehovah are great,","poem":1},{"lineBreak":true},{"text":"Sought out of all them that have pleasure therein.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"His work is honor and majesty;","poem":1},{"lineBreak":true},{"text":"And his righteousness endureth for ever.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"He hath made his wonderful works to be remembered:","poem":1},{"lineBreak":true},{"text":"Jehovah is gracious and merciful.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"He hath given food unto them that fear him:","poem":1},{"lineBreak":true},{"text":"He will ever be mindful of his covenant.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"He hath showed his people the power of his works,","poem":1},{"lineBreak":true},{"text":"In giving them the heritage of the nations.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"The works of his hands are truth and justice;","poem":1},{"lineBreak":true},{"text":"All his precepts are sure.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"They are established for ever and ever;","poem":1},{"lineBreak":true},{"text":"They are done in truth and uprightness.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"He hath sent redemption unto his people;","poem":1},{"lineBreak":true},{"text":"He hath commanded his covenant for ever:","poem":1},{"lineBreak":true},{"text":"Holy and reverend is his name.","poem":1},{"lineBreak":true}]},{"type":"verse","number":10,"content":[{"text":"The fear of Jehovah is the beginning of wisdom;","poem":1},{"lineBreak":true},{"text":"A good understanding have all they that do his commandments:","poem":1},{"lineBreak":true},{"text":"His praise endureth for ever.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/111.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/112.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/110.json","previousChapterAudioLinks":{},"numberOfVerses":10}
