{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":130,"content":[{"type":"hebrew_subtitle","content":["A Song of Ascents."]},{"type":"verse","number":1,"content":[{"text":"Out of the depths have I cried unto thee, O Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Lord, hear my voice:","poem":1},{"lineBreak":true},{"text":"Let thine ears be attentive","poem":1},{"lineBreak":true},{"text":"To the voice of my supplications.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"If thou, Jehovah, shouldest mark iniquities,","poem":1},{"lineBreak":true},{"text":"O Lord, who could stand?","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"But there is forgiveness with thee,","poem":1},{"lineBreak":true},{"text":"That thou mayest be feared.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"I wait for Jehovah, my soul doth wait,","poem":1},{"lineBreak":true},{"text":"And in his word do I hope.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"My soul waiteth for the Lord","poem":1},{"lineBreak":true},{"text":"More than watchmen wait for the morning;","poem":1},{"lineBreak":true},{"text":"Yea, more than watchmen for the morning.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"O Israel, hope in Jehovah;","poem":1},{"lineBreak":true},{"text":"For with Jehovah there is lovingkindness,","poem":1},{"lineBreak":true},{"text":"And with him is plenteous redemption.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"And he will redeem Israel","poem":1},{"lineBreak":true},{"text":"From all his iniquities.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/130.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/131.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/129.json","previousChapterAudioLinks":{},"numberOfVerses":8}
