{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":1,"content":[{"type":"verse","number":1,"content":[{"text":"Blessed is the man that walketh not in the counsel of the wicked,","poem":1},{"lineBreak":true},{"text":"Nor standeth in the way of sinners,","poem":1},{"lineBreak":true},{"text":"Nor sitteth in the seat of scoffers:","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"But his delight is in the law of Jehovah;","poem":1},{"lineBreak":true},{"text":"And on his law doth he meditate day and night.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"And he shall be like a tree planted by the streams of water,","poem":1},{"lineBreak":true},{"text":"That bringeth forth its fruit in its season,","poem":1},{"lineBreak":true},{"text":"Whose leaf also doth not wither;","poem":1},{"lineBreak":true},{"text":"And whatsoever he doeth shall prosper.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"The wicked are not so,","poem":1},{"lineBreak":true},{"text":"But are like the chaff which the wind driveth away.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Therefore the wicked shall not stand in the judgment,","poem":1},{"lineBreak":true},{"text":"Nor sinners in the congregation of the righteous.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"For Jehovah knoweth the way of the righteous;","poem":1},{"lineBreak":true},{"text":"But the way of the wicked shall perish.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/1.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/2.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/JOB/42.json","previousChapterAudioLinks":{},"numberOfVerses":6}
