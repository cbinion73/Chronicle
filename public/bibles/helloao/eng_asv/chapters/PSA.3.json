{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":3,"content":[{"type":"hebrew_subtitle","content":["A Psalm of David, when he fled from Absalom his son."]},{"type":"verse","number":1,"content":[{"text":"Jehovah, how are mine adversaries increased!","poem":1},{"lineBreak":true},{"text":"Many are they that rise up against me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Many there are that say of my soul,","poem":1},{"lineBreak":true},{"text":"There is no help for him in God. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"But thou, O Jehovah, art a shield about me;","poem":1},{"lineBreak":true},{"text":"My glory, and the lifter up of my head.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"I cry unto Jehovah with my voice,","poem":1},{"lineBreak":true},{"text":"And he answereth me out of his holy hill. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"I laid me down and slept;","poem":1},{"lineBreak":true},{"text":"I awaked; for Jehovah sustaineth me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"I will not be afraid of ten thousands of the people","poem":1},{"lineBreak":true},{"text":"That have set themselves against me round about.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Arise, O Jehovah; save me, O my God:","poem":1},{"lineBreak":true},{"text":"For thou hast smitten all mine enemies upon the cheek bone;","poem":1},{"lineBreak":true},{"text":"Thou hast broken the teeth of the wicked.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Salvation belongeth unto Jehovah:","poem":1},{"lineBreak":true},{"text":"Thy blessing be upon thy people. [Selah","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/3.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/4.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/2.json","previousChapterAudioLinks":{},"numberOfVerses":8}
