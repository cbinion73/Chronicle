{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":113,"content":[{"type":"verse","number":1,"content":[{"text":"Praise ye Jehovah.","poem":1},{"lineBreak":true},{"text":"Praise, O ye servants of Jehovah,","poem":1},{"lineBreak":true},{"text":"Praise the name of Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Blessed be the name of Jehovah","poem":1},{"lineBreak":true},{"text":"From this time forth and for evermore.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"From the rising of the sun unto the going down of the same","poem":1},{"lineBreak":true},{"text":"Jehovah’s name is to be praised.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Jehovah is high above all nations,","poem":1},{"lineBreak":true},{"text":"And his glory above the heavens.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Who is like unto Jehovah our God,","poem":1},{"lineBreak":true},{"text":"That hath his seat on high,","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"That humbleth himself to behold","poem":1},{"lineBreak":true},{"text":"The things that are in heaven and in the earth?","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"He raiseth up the poor out of the dust,","poem":1},{"lineBreak":true},{"text":"And lifteth up the needy from the dunghill;","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"That he may set him with princes,","poem":1},{"lineBreak":true},{"text":"Even with the princes of his people.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"He maketh the barren woman to keep house,","poem":1},{"lineBreak":true},{"text":"And to be a joyful mother of children.","poem":1},{"lineBreak":true},{"text":"Praise ye Jehovah.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/113.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/114.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/112.json","previousChapterAudioLinks":{},"numberOfVerses":9}
