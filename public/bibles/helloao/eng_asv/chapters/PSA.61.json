{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":61,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician; on a stringed instrument. A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Hear my cry, O God;","poem":1},{"lineBreak":true},{"text":"Attend unto my prayer.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"From the end of the earth will I call unto thee, when my heart is overwhelmed:","poem":1},{"lineBreak":true},{"text":"Lead me to the rock that is higher than I.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"For thou hast been a refuge for me,","poem":1},{"lineBreak":true},{"text":"A strong tower from the enemy.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"I will dwell in thy tabernacle for ever:","poem":1},{"lineBreak":true},{"text":"I will take refuge in the covert of thy wings. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"For thou, O God, hast heard my vows:","poem":1},{"lineBreak":true},{"text":"Thou hast given me the heritage of those that fear thy name.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Thou wilt prolong the king’s life;","poem":1},{"lineBreak":true},{"text":"His years shall be as many generations.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"He shall abide before God for ever:","poem":1},{"lineBreak":true},{"text":"Oh prepare lovingkindness and truth, that they may preserve him.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"So will I sing praise unto thy name for ever,","poem":1},{"lineBreak":true},{"text":"That I may daily perform my vows.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/61.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/62.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/60.json","previousChapterAudioLinks":{},"numberOfVerses":8}
