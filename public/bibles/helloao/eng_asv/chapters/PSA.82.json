"lineBreak":true},{"text":"They walk to and fro in darkness:","poem":1},{"lineBreak":true},{"text":"All the foundations of the earth are shaken.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"I said, Ye are gods,","poem":1},{"lineBreak":true},{"text":"And all of you sons of the Most High.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Nevertheless ye shall die like men,","poem":1},{"lineBreak":true},{"text":"And fall like one of the princes.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Arise, O God, judge the earth;","poem":1},{"lineBreak":true},{"text":"For thou shalt inherit all the nations.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/82.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/83.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/81.json","previousChapterAudioLinks":{},"numberOfVerses":8}
