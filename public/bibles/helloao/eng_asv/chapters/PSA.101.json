{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":101,"content":[{"type":"hebrew_subtitle","content":["A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"I will sing of lovingkindness and justice:","poem":1},{"lineBreak":true},{"text":"Unto thee, O Jehovah, will I sing praises.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"I will behave myself wisely in a perfect way:","poem":1},{"lineBreak":true},{"text":"Oh when wilt thou come unto me?","poem":1},{"lineBreak":true},{"text":"I will walk within my house with a perfect heart.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"I will set no base thing before mine eyes:","poem":1},{"lineBreak":true},{"text":"I hate the work of them that turn aside;","poem":1},{"lineBreak":true},{"text":"It shall not cleave unto me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"A perverse heart shall depart from me:","poem":1},{"lineBreak":true},{"text":"I will know no evil thing.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Whoso privily slandereth his neighbor, him will I destroy:","poem":1},{"lineBreak":true},{"text":"Him that hath a high look and a proud heart will I not suffer.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Mine eyes shall be upon the faithful of the land, that they may dwell with me:","poem":1},{"lineBreak":true},{"text":"He that walketh in a perfect way, he shall minister unto me.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"He that worketh deceit shall not dwell within my house:","poem":1},{"lineBreak":true},{"text":"He that speaketh falsehood shall not be established before mine eyes.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Morning by morning will I destroy all the wicked of the land;","poem":1},{"lineBreak":true},{"text":"To cut off all the workers of iniquity from the city of Jehovah.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/101.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/102.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/100.json","previousChapterAudioLinks":{},"numberOfVerses":8}
