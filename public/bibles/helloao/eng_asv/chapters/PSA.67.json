n earth. [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Let the peoples praise thee, O God;","poem":1},{"lineBreak":true},{"text":"Let all the peoples praise thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"The earth hath yielded its increase:","poem":1},{"lineBreak":true},{"text":"God, even our own God, will bless us.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"God will bless us;","poem":1},{"lineBreak":true},{"text":"And all the ends of the earth shall fear him.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/67.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/68.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/66.json","previousChapterAudioLinks":{},"numberOfVerses":7}
