{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":20,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"Jehovah answer thee in the day of trouble;","poem":1},{"lineBreak":true},{"text":"The name of the God of Jacob set thee up on high;","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Send thee help from the sanctuary,","poem":1},{"lineBreak":true},{"text":"And strengthen thee out of Zion;","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Remember all thy offerings,","poem":1},{"lineBreak":true},{"text":"And accept thy burnt-sacrifice; [Selah","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Grant thee thy heart’s desire,","poem":1},{"lineBreak":true},{"text":"And fulfil all thy counsel.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"We will triumph in thy salvation,","poem":1},{"lineBreak":true},{"text":"And in the name of our God we will set up our banners:","poem":1},{"lineBreak":true},{"text":"Jehovah fulfil all thy petitions.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Now know I that Jehovah saveth his anointed;","poem":1},{"lineBreak":true},{"text":"He will answer him from his holy heaven","poem":1},{"lineBreak":true},{"text":"With the saving strength of his right hand.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Some trust in chariots, and some in horses;","poem":1},{"lineBreak":true},{"text":"But we will make mention of the name of Jehovah our God.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"They are bowed down and fallen;","poem":1},{"lineBreak":true},{"text":"But we are risen, and stand upright.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"Save, Jehovah:","poem":1},{"lineBreak":true},{"text":"Let the King answer us when we call.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/20.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/21.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/19.json","previousChapterAudioLinks":{},"numberOfVerses":9}
