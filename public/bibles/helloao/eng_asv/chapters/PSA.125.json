"text":"And to them that are upright in their hearts.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"But as for such as turn aside unto their crooked ways,","poem":1},{"lineBreak":true},{"text":"Jehovah will lead them forth with the workers of iniquity.","poem":1},{"lineBreak":true},{"text":"Peace be upon Israel.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/125.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/126.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/124.json","previousChapterAudioLinks":{},"numberOfVerses":5}
