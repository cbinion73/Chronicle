:true},{"text":"He that sweareth to his own hurt, and changeth not;","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"He that putteth not out his money to interest,","poem":1},{"lineBreak":true},{"text":"Nor taketh reward against the innocent.","poem":1},{"lineBreak":true},{"text":"He that doeth these things shall never be moved.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/15.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/16.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/14.json","previousChapterAudioLinks":{},"numberOfVerses":5}
