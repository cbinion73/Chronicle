rue}]},{"type":"verse","number":6,"content":[{"text":"Ye mountains, that ye skip like rams;","poem":1},{"lineBreak":true},{"text":"Ye little hills, like lambs?","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Tremble, thou earth, at the presence of the Lord,","poem":1},{"lineBreak":true},{"text":"At the presence of the God of Jacob,","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"Who turned the rock into a pool of water,","poem":1},{"lineBreak":true},{"text":"The flint into a fountain of waters.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/114.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/115.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/113.json","previousChapterAudioLinks":{},"numberOfVerses":8}
