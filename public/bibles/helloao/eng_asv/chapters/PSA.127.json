{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":127,"content":[{"type":"hebrew_subtitle","content":["A Song of Ascents; of Solomon."]},{"type":"verse","number":1,"content":[{"text":"Except Jehovah build the house,","poem":1},{"lineBreak":true},{"text":"They labor in vain that build it:","poem":1},{"lineBreak":true},{"text":"Except Jehovah keep the city,","poem":1},{"lineBreak":true},{"text":"The watchman waketh but in vain.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"It is vain for you to rise up early,","poem":1},{"lineBreak":true},{"text":"To take rest late,","poem":1},{"lineBreak":true},{"text":"To eat the bread of toil;","poem":1},{"lineBreak":true},{"text":"For so he giveth unto his beloved sleep.","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Lo, children are a heritage of Jehovah;","poem":1},{"lineBreak":true},{"text":"And the fruit of the womb is his reward.","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"As arrows in the hand of a mighty man,","poem":1},{"lineBreak":true},{"text":"So are the children of youth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Happy is the man that hath his quiver full of them:","poem":1},{"lineBreak":true},{"text":"They shall not be put to shame,","poem":1},{"lineBreak":true},{"text":"When they speak with their enemies in the gate.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/127.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/128.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/126.json","previousChapterAudioLinks":{},"numberOfVerses":5}
