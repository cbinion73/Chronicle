":true}]},{"type":"verse","number":5,"content":[{"text":"For Jehovah is good; his lovingkindness endureth for ever,","poem":1},{"lineBreak":true},{"text":"And his faithfulness unto all generations.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/100.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/101.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/99.json","previousChapterAudioLinks":{},"numberOfVerses":5}
