{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":11,"content":[{"type":"hebrew_subtitle","content":["For the Chief Musician. A Psalm of David."]},{"type":"verse","number":1,"content":[{"text":"In Jehovah do I take refuge:","poem":1},{"lineBreak":true},{"text":"How say ye to my soul,","poem":1},{"lineBreak":true},{"text":"Flee as a bird to your mountain;","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"For, lo, the wicked bend the bow,","poem":1},{"lineBreak":true},{"text":"They make ready their arrow upon the string,","poem":1},{"lineBreak":true},{"text":"That they may shoot in darkness at the upright in heart;","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"If the foundations be destroyed,","poem":1},{"lineBreak":true},{"text":"What can the righteous do?","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Jehovah is in his holy temple;","poem":1},{"lineBreak":true},{"text":"Jehovah, his throne is in heaven;","poem":1},{"lineBreak":true},{"text":"His eyes behold, his eyelids try, the children of men.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"Jehovah trieth the righteous;","poem":1},{"lineBreak":true},{"text":"But the wicked and him that loveth violence his soul hateth.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Upon the wicked he will rain snares;","poem":1},{"lineBreak":true},{"text":"Fire and brimstone and burning wind shall be the portion of their cup.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"For Jehovah is righteous; he loveth righteousness:","poem":1},{"lineBreak":true},{"text":"The upright shall behold his face.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/11.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/12.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/10.json","previousChapterAudioLinks":{},"numberOfVerses":7}
