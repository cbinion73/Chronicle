{"translation":{"id":"eng_asv","name":"American Standard Version (1901)","website":"https://ebible.org/Scriptures/details.php?id=eng-asv","licenseUrl":"https://ebible.org/Scriptures/details.php?id=eng-asv","shortName":"ASV","englishName":"American Standard Version (1901)","language":"eng","textDirection":"ltr","sha256":"154967f9f68504bdf9a8d7abaae4ef6a93f20f779df84e62c1c8828427731839","availableFormats":["json"],"listOfBooksApiLink":"/api/eng_asv/books.json","completeTranslationApiLink":"/api/eng_asv/complete.json","numberOfBooks":66,"totalNumberOfChapters":1189,"totalNumberOfVerses":31102,"languageName":"English","languageEnglishName":"English"},"book":{"id":"PSA","translationId":"eng_asv","name":"Psalms","commonName":"Psalms","title":"THE PSALMS","order":19,"numberOfChapters":150,"sha256":"48a939ab77d764e2a7ea001433ea661306ac0f9eafa3df5ad760a204c8eb6fa0","firstChapterNumber":1,"firstChapterApiLink":"/api/eng_asv/PSA/1.json","lastChapterNumber":150,"lastChapterApiLink":"/api/eng_asv/PSA/150.json","totalNumberOfVerses":2461},"chapter":{"number":122,"content":[{"type":"hebrew_subtitle","content":["A Song of Ascents; of David."]},{"type":"verse","number":1,"content":[{"text":"I was glad when they said unto me,","poem":1},{"lineBreak":true},{"text":"Let us go unto the house of Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":2,"content":[{"text":"Our feet are standing","poem":1},{"lineBreak":true},{"text":"Within thy gates, O Jerusalem,","poem":1},{"lineBreak":true}]},{"type":"verse","number":3,"content":[{"text":"Jerusalem, that art builded","poem":1},{"lineBreak":true},{"text":"As a city that is compact together;","poem":1},{"lineBreak":true}]},{"type":"verse","number":4,"content":[{"text":"Whither the tribes go up, even the tribes of Jehovah,","poem":1},{"lineBreak":true},{"text":"For an ordinance for Israel,","poem":1},{"lineBreak":true},{"text":"To give thanks unto the name of Jehovah.","poem":1},{"lineBreak":true}]},{"type":"verse","number":5,"content":[{"text":"For there are set thrones for judgment,","poem":1},{"lineBreak":true},{"text":"The thrones of the house of David.","poem":1},{"lineBreak":true}]},{"type":"verse","number":6,"content":[{"text":"Pray for the peace of Jerusalem:","poem":1},{"lineBreak":true},{"text":"They shall prosper that love thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":7,"content":[{"text":"Peace be within thy walls,","poem":1},{"lineBreak":true},{"text":"And prosperity within thy palaces.","poem":1},{"lineBreak":true}]},{"type":"verse","number":8,"content":[{"text":"For my brethren and companions’ sakes,","poem":1},{"lineBreak":true},{"text":"I will now say, Peace be within thee.","poem":1},{"lineBreak":true}]},{"type":"verse","number":9,"content":[{"text":"For the sake of the house of Jehovah our God","poem":1},{"lineBreak":true},{"text":"I will seek thy good.","poem":1}]}],"footnotes":[]},"thisChapterLink":"/api/eng_asv/PSA/122.json","thisChapterAudioLinks":{},"nextChapterApiLink":"/api/eng_asv/PSA/123.json","nextChapterAudioLinks":{},"previousChapterApiLink":"/api/eng_asv/PSA/121.json","previousChapterAudioLinks":{},"numberOfVerses":9}
